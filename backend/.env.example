# Configuration de l'application
APP_PORT=2023
APP_BASE_URL=/api
APP_MODE=development

# Configuration de la base de données
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=lag_admin
DB_PASSWORD=changeme
DB_DATABASE=lag_db
DB_SYNC=true

# Configuration JWT
JWT_TOKEN_SECRET=your-secret-key-change-in-production
JWT_TOKEN_EXPIRE_IN=8h
JWT_REFRESH_TOKEN_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_TOKEN_EXPIRE_IN=7d

# Webhook site vitrine (send-mail.php / send-order.php)
# Secret partagé vérifié via le header x-webhook-secret sur POST /api/orders/webhook.
# Doit correspondre à GRAVISTERIE_API_WEBHOOK_SECRET défini dans send-mail.php et send-order.php.
# Générer avec : openssl rand -hex 32
WEBHOOK_SECRET=change-me-strong-random-secret

# R2 (Cloudflare) - Fichiers des commandes
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-r2-bucket-name
